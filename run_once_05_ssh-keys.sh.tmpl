#!/usr/bin/env bash
set -euo pipefail

MACHINE="{{ .machineName }}"

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
source "$HOME/.config/chezmoi/bw-helper.sh"
bw_ensure_unlocked

SSH_DIR="$HOME/.ssh"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

PRIV_KEY_FILE="$SSH_DIR/${MACHINE}_id_ed25519"
PUB_KEY_FILE="${PRIV_KEY_FILE}.pub"

echo "Fetching SSH keys for $MACHINE from Bitwarden..."

# Extract private and public key from native SSH key item (type 5)
BW_ITEM=$(BW_SESSION="$BW_SESSION" bw get item "$MACHINE")
PRIVATE_KEY=$(echo "$BW_ITEM" | python3 -c "
import sys, json
item = json.load(sys.stdin)
print(item.get('sshKey', {}).get('privateKey', ''))
")

PUBLIC_KEY=$(echo "$BW_ITEM" | python3 -c "
import sys, json
item = json.load(sys.stdin)
print(item.get('sshKey', {}).get('publicKey', ''))
")

if [ -z "$PRIVATE_KEY" ] || [ -z "$PUBLIC_KEY" ]; then
  echo "ERROR: Could not find SSH key data in Bitwarden item '$MACHINE'"
  echo "Make sure the item is type 'SSH Key' (not Secure Note) and has privateKey/publicKey set."
  exit 1
fi

# Write keys
printf '%s\n' "$PRIVATE_KEY" > "$PRIV_KEY_FILE"
printf '%s\n' "$PUBLIC_KEY"  > "$PUB_KEY_FILE"
chmod 600 "$PRIV_KEY_FILE"
chmod 644 "$PUB_KEY_FILE"

# Write allowed_signers for SSH commit verification
ALLOWED_SIGNERS="$SSH_DIR/allowed_signers"
PUB_KEY_CONTENT=$(cat "$PUB_KEY_FILE")
# Remove existing entry for this key (match on key body, not machine name) then add fresh
KEY_BODY=$(awk '{print $2}' "$PUB_KEY_FILE")
grep -v "$KEY_BODY" "$ALLOWED_SIGNERS" > /tmp/allowed_signers_tmp 2>/dev/null || true
echo "jreilly1821@gmail.com namespaces=\"git\" $PUB_KEY_CONTENT" >> /tmp/allowed_signers_tmp
mv /tmp/allowed_signers_tmp "$ALLOWED_SIGNERS"
chmod 644 "$ALLOWED_SIGNERS"

echo "SSH keys for $MACHINE written to $SSH_DIR"
echo "allowed_signers updated."
