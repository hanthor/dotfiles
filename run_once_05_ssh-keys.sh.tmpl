#!/usr/bin/env bash
set -euo pipefail

MACHINE="{{ .machineName }}"

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
source "$HOME/.config/chezmoi/bw-helper.sh"
bw_ensure_unlocked

SSH_DIR="$HOME/.ssh"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

PRIV_KEY_FILE="$SSH_DIR/${MACHINE}_id_ed25519"
PUB_KEY_FILE="${PRIV_KEY_FILE}.pub"

echo "Looking up SSH key for $MACHINE in Bitwarden..."
BW_ITEM=$(BW_SESSION="$BW_SESSION" bw get item "$MACHINE" 2>/dev/null || echo "")
PRIVATE_KEY=""
PUBLIC_KEY=""

if [ -n "$BW_ITEM" ]; then
  PRIVATE_KEY=$(echo "$BW_ITEM" | python3 -c "
import sys, json
item = json.load(sys.stdin)
print(item.get('sshKey', {}).get('privateKey', ''))
" 2>/dev/null || echo "")
  PUBLIC_KEY=$(echo "$BW_ITEM" | python3 -c "
import sys, json
item = json.load(sys.stdin)
print(item.get('sshKey', {}).get('publicKey', ''))
" 2>/dev/null || echo "")
fi

if [ -z "$PRIVATE_KEY" ] || [ -z "$PUBLIC_KEY" ]; then
  echo "No SSH key found in Bitwarden for '$MACHINE' — generating a new one..."
  ssh-keygen -t ed25519 -C "${MACHINE}" -f "$PRIV_KEY_FILE" -N ""
  PRIVATE_KEY=$(cat "$PRIV_KEY_FILE")
  PUBLIC_KEY=$(cat "$PUB_KEY_FILE")

  echo "Storing new key in Bitwarden..."
  BW_SESSION="$BW_SESSION" bw create item "$(cat <<EOF
{
  "type": 5,
  "name": "$MACHINE",
  "sshKey": {
    "privateKey": $(echo "$PRIVATE_KEY" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))"),
    "publicKey": $(echo "$PUBLIC_KEY" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read().strip()))"),
    "keyFingerprint": ""
  }
}
EOF
)" >/dev/null
  echo "Key stored in Bitwarden."
else
  echo "Found SSH key in Bitwarden, writing to disk..."
  printf '%s\n' "$PRIVATE_KEY" > "$PRIV_KEY_FILE"
  printf '%s\n' "$PUBLIC_KEY"  > "$PUB_KEY_FILE"
fi

chmod 600 "$PRIV_KEY_FILE"
chmod 644 "$PUB_KEY_FILE"

# Update allowed_signers for SSH commit verification
ALLOWED_SIGNERS="$SSH_DIR/allowed_signers"
KEY_BODY=$(awk '{print $2}' "$PUB_KEY_FILE")
PUB_KEY_CONTENT=$(cat "$PUB_KEY_FILE")
grep -v "$KEY_BODY" "$ALLOWED_SIGNERS" > /tmp/allowed_signers_tmp 2>/dev/null || true
echo "jreilly1821@gmail.com namespaces=\"git\" $PUB_KEY_CONTENT" >> /tmp/allowed_signers_tmp
mv /tmp/allowed_signers_tmp "$ALLOWED_SIGNERS"
chmod 644 "$ALLOWED_SIGNERS"

echo "SSH key for $MACHINE ready at $PRIV_KEY_FILE"
echo "allowed_signers updated."
