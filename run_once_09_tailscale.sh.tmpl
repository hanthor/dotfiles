#!/usr/bin/env bash
set -euo pipefail

MACHINE="{{ .machineName }}"

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
source "$HOME/.config/chezmoi/bw-helper.sh"
bw_ensure_unlocked

# Skip if already connected to Tailscale
if tailscale status &>/dev/null 2>&1; then
  echo "Tailscale already connected, skipping."
  exit 0
fi

# Install Tailscale if not present
if ! command -v tailscale &>/dev/null; then
  echo "Installing Tailscale..."
  if command -v ujust &>/dev/null; then
    ujust install-tailscale || true
  fi
  if ! command -v tailscale &>/dev/null; then
    curl -fsSL https://tailscale.com/install.sh | sh
  fi
fi

# Fetch Tailscale auth key from Bitwarden and join the network
echo "Fetching Tailscale auth key from Bitwarden..."
TAILSCALE_KEY=$(BW_SESSION="$BW_SESSION" bw get password tailscale-authkey)

if [ -z "$TAILSCALE_KEY" ]; then
  echo "ERROR: Could not fetch tailscale-authkey from Bitwarden."
  exit 1
fi

echo "Joining Tailscale network as $MACHINE..."
sudo tailscale up --authkey "$TAILSCALE_KEY" --hostname "$MACHINE"
echo "Tailscale connected."
