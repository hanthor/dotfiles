{# Show only this machine's own services, grouped by 'group' field #}
{% set ns = namespace(groups={}) %}
{% for svc in web_services | default([]) %}
{%   set g = svc.get('group', 'Services') %}
{%   if g not in ns.groups %}
{%     set _ = ns.groups.update({g: []}) %}
{%   endif %}
{%   set _ = ns.groups[g].append(svc) %}
{% endfor %}
{% for group_name, svcs in ns.groups.items() %}
- {{ group_name }}:
{% for svc in svcs %}
    - {{ svc.name }}:
        href: {{ svc.href }}
{% if svc.get('icon') %}
        icon: {{ svc.icon }}
{% endif %}
{% if svc.get('description') %}
        description: {{ svc.description }}
{% endif %}
        siteMonitor: {{ svc.get('siteMonitor', svc.href) }}
{% endfor %}
{% endfor %}
{# Fleet section — links to other machines' homepages #}
{% set other_machines = [] %}
{% for host, data in fleet.items() %}
{%   if host != inventory_hostname %}
{%     set _ = other_machines.append((host, data)) %}
{%   endif %}
{% endfor %}
{% if other_machines %}
- Fleet:
{% for host, data in other_machines %}
    - {{ data.name }}:
        href: {{ data.url }}
        icon: {{ data.get('icon', 'mdi-server') }}
        description: {{ data.get('description', host) }}
        siteMonitor: {{ data.url }}
{% endfor %}
{% endif %}
{# Monitoring — Grafana link filtered for this machine on the monitoring hub #}
{%- set _gq = '{"datasource":"Prometheus","queries":[{"expr":"up{machine=\\"' ~ inventory_hostname ~ '\\"}","refId":"A"}],"range":{"from":"now-1h","to":"now"}}' -%}
{%- set _grafana_url = 'http://' ~ monitoring_hub_host ~ ':3000/explore?orgId=1&left=' ~ _gq -%}
- Monitoring:
    - Grafana:
        href: "{{ _grafana_url }}"
        icon: grafana.png
        description: Metrics for {{ inventory_hostname }}
        siteMonitor: http://{{ monitoring_hub_host }}:3000
{% if is_desktop | bool %}
    - Remote Desktop:
        href: https://{{ inventory_hostname }}/lima
        icon: mdi-remote-desktop
        description: RDP via Lima
        siteMonitor: https://{{ inventory_hostname }}/lima
{% endif %}
