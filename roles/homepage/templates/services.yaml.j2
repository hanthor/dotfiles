{# Collect all web_services across the fleet, grouped by 'group' field #}
{# Containers (NetBox, lima, etc.) are auto-discovered via Podman socket labels #}
{% set ns = namespace(groups={}) %}
{% for host in groups['all'] %}
{%   for svc in hostvars[host].get('web_services', []) %}
{%     set g = svc.get('group', 'Other') %}
{%     if g not in ns.groups %}
{%       set _ = ns.groups.update({g: []}) %}
{%     endif %}
{%     set _ = ns.groups[g].append({'host': host, 'svc': svc}) %}
{%   endfor %}
{% endfor %}
{% for group_name, entries in ns.groups.items() %}
- {{ group_name }}:
{% for entry in entries %}
    - {{ entry.svc.name }}{% if entry.svc.get('description') %} ({{ entry.host }}){% endif %}:

        href: {{ entry.svc.href }}
{% if entry.svc.get('icon') %}
        icon: {{ entry.svc.icon }}
{% endif %}
{% if entry.svc.get('description') %}
        description: {{ entry.svc.description }}
{% endif %}
{% if entry.svc.get('siteMonitor') %}
        siteMonitor: {{ entry.svc.siteMonitor }}
{% endif %}
        server: bihar
{% endfor %}
{% endfor %}
