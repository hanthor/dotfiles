{# Show only this machine's own services, grouped by 'group' field #}
{% set ns = namespace(groups={}) %}
{% for svc in web_services | default([]) %}
{%   set g = svc.get('group', 'Services') %}
{%   if g not in ns.groups %}
{%     set _ = ns.groups.update({g: []}) %}
{%   endif %}
{%   set _ = ns.groups[g].append(svc) %}
{% endfor %}
{% for group_name, svcs in ns.groups.items() %}
- {{ group_name }}:
{% for svc in svcs %}
    - {{ svc.name }}:
        href: {{ svc.href }}
{% if svc.get('icon') %}
        icon: {{ svc.icon }}
{% endif %}
{% if svc.get('description') %}
        description: {{ svc.description }}
{% endif %}
        siteMonitor: {{ svc.get('siteMonitor', svc.href) }}
{% endfor %}
{% endfor %}
{# Fleet section — links to other machines' homepages #}
{% set other_machines = [] %}
{% for host, data in fleet.items() %}
{%   if host != inventory_hostname %}
{%     set _ = other_machines.append((host, data)) %}
{%   endif %}
{% endfor %}
{% if other_machines %}
- Fleet:
{% for host, data in other_machines %}
    - {{ data.name }}:
        href: {{ data.url }}
        icon: {{ data.get('icon', 'mdi-server') }}
        description: {{ data.get('description', host) }}
        siteMonitor: {{ data.url }}
{% endfor %}
{% endif %}
{# Monitoring — Grafana link filtered for this machine on the monitoring hub #}
{#  URL-encoded JSON: {"datasource":"Prometheus","queries":[{"expr":"up{machine=\"<host>\"}","refId":"A"}],"range":{"from":"now-1h","to":"now"}} #}
{%- set _gq_pre = '%7B%22datasource%22%3A%22Prometheus%22%2C%22queries%22%3A%5B%7B%22expr%22%3A%22up%7Bmachine%3D%5C%22' -%}
{%- set _gq_suf = '%5C%22%7D%22%2C%22refId%22%3A%22A%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-1h%22%2C%22to%22%3A%22now%22%7D%7D' -%}
{%- set _grafana_url = monitoring_hub_url ~ '/explore?orgId=1&left=' ~ _gq_pre ~ inventory_hostname ~ _gq_suf -%}
- Monitoring:
    - Grafana:
        href: {{ _grafana_url }}
        icon: grafana.png
        description: Metrics for {{ inventory_hostname }}
        siteMonitor: {{ monitoring_hub_url }}
{% if is_desktop | bool %}
    - Remote Desktop:
        href: https://{{ inventory_hostname }}.{{ tailscale_domain }}/lima
        icon: mdi-remote-desktop
        description: RDP via Lima
{% endif %}
