:9000 {
{% for svc in web_services | default([]) %}
    # /service/{{ svc.name | lower | replace(' ', '-') | replace('/', '-') }}
    handle /service/{{ svc.name | lower | replace(' ', '-') | replace('/', '-') }} {
        redir {{ svc.href }} 302
    }
{% endfor %}

{% if inventory_hostname == 'bihar' %}
    # /auth — Authentik SSO
    handle /auth* {
        reverse_proxy 10.88.0.1:9443 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    # /n8n — n8n automation
    handle /n8n* {
        reverse_proxy 10.88.0.1:5678
    }

    # /appflowy — AppFlowy Cloud
    handle /appflowy* {
        reverse_proxy 10.88.0.1:8000
    }

    # /netbox — NetBox source of truth
    redir /netbox /netbox/ 301
    handle /netbox* {
        reverse_proxy 10.88.0.1:8080
    }

    # /grafana — Grafana metrics dashboard
    handle /grafana* {
        reverse_proxy 10.88.0.1:3001
    }

{% endif %}
    # /cockpit — Cockpit system management (sub-path proxy)
    redir /cockpit /cockpit/ 301
    handle /cockpit/* {
        reverse_proxy https://10.88.0.1:9095 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

{% if inventory_hostname == 'bihar' %}
    # /proxmox — Proxmox VE sub-path proxy
    # Entry point strips /proxmox prefix; resource paths (/pve2/, /api2/, etc.)
    # are intercepted at root since PVE JS uses absolute paths.
    redir /proxmox /proxmox/ 301
    handle /proxmox/* {
        uri strip_prefix /proxmox
        reverse_proxy https://127.0.0.1:8006 {
            transport http {
                tls_insecure_skip_verify
            }
            @redirect status 301 302 303 307 308
            handle_response @redirect {
                redir /proxmox{rp.header.Location} {rp.status_code}
            }
        }
    }
    @pve_resources path /pve2/* /api2/* /novnc/* /xtermjs/*
    handle @pve_resources {
        reverse_proxy https://127.0.0.1:8006 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

{% endif %}
{% if is_desktop | bool or inventory_hostname == 'bihar' %}
    # /rdp — shortcut redirect to Lima RDP client
    handle /rdp* {
        redir /lima/rdp/ 302
    }

{% endif %}
{% if is_desktop | bool or inventory_hostname == 'bihar' %}
    # /lima — lima-bootc VM dashboard and RDP client
    handle /lima* {
        uri strip_prefix /lima
        reverse_proxy https://10.88.0.1:{{ lima_internal_port | default(8007) }} {
            transport http {
                tls_insecure_skip_verify
            }
            @redirect status 301 302 303 307 308
            handle_response @redirect {
                redir /lima{rp.header.Location} {rp.status_code}
            }
        }
    }

{% endif %}
    # /bst — BuildStream live build dashboard 
    redir /bst /bst/ 301 
    handle /bst/* { 
        uri strip_prefix /bst 
        reverse_proxy 10.88.0.1:8765 
    }

    # / — homepage dashboard
    handle {
        reverse_proxy 10.88.0.1:3000
    }
}
