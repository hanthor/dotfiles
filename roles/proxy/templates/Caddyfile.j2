:9000 {
{% for svc in web_services | default([]) %}
    # /service/{{ svc.name | lower | replace(' ', '-') | replace('/', '-') }}
    handle /service/{{ svc.name | lower | replace(' ', '-') | replace('/', '-') }} {
        redir {{ svc.href }} 302
    }
{% endfor %}

{% if inventory_hostname == 'bihar' %}
    # /proxmox — redirect to direct Proxmox port (PVE uses absolute paths, can't sub-path proxy)
    @proxmox path /proxmox /proxmox/*
    redir @proxmox https://{{ proxy_tailscale_host | default('bihar.manatee-basking.ts.net') }}:8006 302

{% endif %}
{% if is_desktop | bool or inventory_hostname == 'bihar' %}
    # /lima — lima-bootc VM dashboard and RDP client
    handle /lima* {
        uri strip_prefix /lima
        reverse_proxy https://host.containers.internal:{{ lima_internal_port | default(8007) }} {
            transport http {
                tls_insecure_skip_verify
            }
            @redirect status 301 302 303 307 308
            handle_response @redirect {
                redir /lima{rp.header.Location} {rp.status_code}
            }
        }
    }

{% endif %}
    # / — homepage dashboard
    handle {
        reverse_proxy host.containers.internal:3000
    }
}
