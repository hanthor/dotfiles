[Container]
ContainerName=authentik-db
Image=docker.io/library/postgres:16-alpine
Environment=POSTGRES_USER=authentik
Environment=POSTGRES_PASSWORD={{ authentik_pg_password }}
Environment=POSTGRES_DB=authentik
Volume=authentik-db-data:/var/lib/postgresql/data:Z
Network=authentik.network

[Service]
Restart=always

[Install]
WantedBy=default.target
