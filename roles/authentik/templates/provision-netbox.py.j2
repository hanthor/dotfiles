import sys
from authentik.core.models import Application
from authentik.providers.oauth2.models import OAuth2Provider
from authentik.flows.models import Flow

# Configuration
APP_NAME = "NetBox"
APP_SLUG = "netbox"
CLIENT_ID = "{{ netbox_oidc_client_id }}"
CLIENT_SECRET = "{{ netbox_oidc_client_secret }}"
REDIRECT_URI = "https://bihar.manatee-basking.ts.net:8444/oauth/complete/oidc/"

print(f"Ensuring OIDC Provider for {APP_NAME} exists...")

# Get the default authorization flow
auth_flow = Flow.objects.filter(slug="default-provider-authorization-implicit-consent").first()
if not auth_flow:
    auth_flow = Flow.objects.all().first()
    print(f"Warning: Using fallback flow {auth_flow.slug}")

# Find or Create Provider
provider = OAuth2Provider.objects.filter(name=APP_NAME).first()
if not provider:
    print(f"Creating new Provider: {APP_NAME}")
    # Create without redirect_uris to avoid asdict() bug
    provider = OAuth2Provider.objects.create(
        name=APP_NAME,
        client_id=CLIENT_ID,
        client_secret=CLIENT_SECRET,
        authorization_flow=auth_flow,
    )
else:
    print(f"Updating existing Provider: {APP_NAME}")
    provider.client_id = CLIENT_ID
    provider.client_secret = CLIENT_SECRET
    provider.authorization_flow = auth_flow

# Set redirect URIs safely
provider.redirect_uris = REDIRECT_URI
provider.save()

# Find or Create Application
app = Application.objects.filter(slug=APP_SLUG).first()
if not app:
    print(f"Creating new Application: {APP_NAME}")
    app = Application.objects.create(
        name=APP_NAME,
        slug=APP_SLUG,
        provider=provider,
    )
else:
    print(f"Updating existing Application: {APP_NAME}")
    app.name = APP_NAME
    app.provider = provider
    app.save()

print("Provisioning complete.")
