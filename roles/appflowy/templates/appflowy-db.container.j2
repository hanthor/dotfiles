[Container]
ContainerName=appflowy-db
Image=docker.io/pgvector/pgvector:pg16
Environment=POSTGRES_USER=appflowy
Environment=POSTGRES_PASSWORD={{ appflowy_db_password }}
Environment=POSTGRES_DB=appflowy
Volume=appflowy-db-data:/var/lib/postgresql/data:Z
Network=appflowy.network

[Service]
Restart=always

[Install]
WantedBy=default.target
