        pod = res.stdout.strip()
        if not pod:
            print_error(f"No virt-launcher pod for VM '{name}'.")
            sys.exit(1)
        gum_section(f"Logs: pod/{pod}")
        subprocess.run(["kubectl", "logs", "-f", pod, "-n", ns])
    except KeyboardInterrupt:
        print()
    except Exception as e:
        print_error(f"Failed: {e}")


