def cmd_kubevirt_create(args: argparse.Namespace) -> None:
    name = args.name
    ns = args.namespace or "default"
    password = args.cloud_init_password or _random_password()

    has_iso = bool(args.iso)
    has_container = bool(args.container_disk)
    has_existing_pvc = bool(args.pvc)

    # Create PVCs
    if has_iso:
        # Create DataVolume to import the ISO from URL
        iso_dv = generate_iso_pvc_manifest(f"{name}-iso", ns, args.iso)
        gum_spin(
            f"Creating DataVolume {name}-iso (CDI will download the ISO)",
            ["kubectl", "apply", "-f", "-"],
            input=json.dumps(iso_dv), text=True, capture_output=True, check=True,
        )
        print_info(f"ISO DataVolume: {name}-iso (importing from {args.iso})")
        # Create boot disk PVC for install target
        disk_size = args.disk or "20G"
        boot_pvc = generate_pvc_manifest(f"{name}-disk", ns, disk_size)
        gum_spin(
            f"Creating boot disk PVC {name}-disk",
            ["kubectl", "apply", "-f", "-"],
            input=json.dumps(boot_pvc), text=True, capture_output=True, check=True,
        )
        print_info(f"Boot PVC: {name}-disk ({disk_size})")
    elif has_existing_pvc:
        pass
    elif has_container:
        if args.disk:
            pvc = generate_pvc_manifest(f"{name}-data", ns, args.disk)
            gum_spin(
                f"Creating data PVC {name}-data",
                ["kubectl", "apply", "-f", "-"],
                input=json.dumps(pvc), text=True, capture_output=True, check=True,
            )
            print_info(f"Data PVC: {name}-data ({args.disk})")
    else:
        disk_size = args.disk or "20G"
        pvc = generate_pvc_manifest(f"{name}-disk", ns, disk_size)
        gum_spin(
            f"Creating boot PVC {name}-disk",
            ["kubectl", "apply", "-f", "-"],
            input=json.dumps(pvc), text=True, capture_output=True, check=True,
        )
        print_info(f"Boot PVC: {name}-disk ({disk_size})")

    # Build and apply VM
    # Load extra cloud-init if --cloud-init points to a file or inline YAML
    cloud_init_extra = None
    if args.cloud_init:
        if os.path.isfile(os.path.expanduser(args.cloud_init)):
            cloud_init_extra = open(os.path.expanduser(args.cloud_init)).read()
        else:
            cloud_init_extra = args.cloud_init

    manifest = generate_kubevirt_vm_manifest(
        name=name, namespace=ns, cpu=args.cpu, mem=args.mem,
        container_disk=args.container_disk if not has_iso else None,
        pvc_name=args.pvc,
        disk_size=args.disk if (has_container and not has_iso) else None,
        cloud_init_password=password,
        iso_url=args.iso if has_iso else None,
        cloud_init_extra=cloud_init_extra,
    )
    if args.node:
        manifest["spec"]["template"]["spec"]["nodeSelector"] = {
            "kubernetes.io/hostname": args.node,
        }

    gum_spin(
        f"Creating KubeVirt VM '{name}'",
        ["kubectl", "apply", "-f", "-"],
        input=json.dumps(manifest), text=True, capture_output=True, check=True,
    )

    registry_set(name, "kubevirt", {
        "namespace": ns,
        "cloud_init_password": password,
    })

    gum_print_header(f"VM '{name}' created in ns/{ns}")
    if has_iso:
        gum_section("ISO Mode")
        print_info("CDI is importing the ISO — wait for the import to complete:")
        print_info(f"  kubectl get pvc {name}-iso -n {ns} -w")
        gum_section("Cloud-init password (save this!)")
        if GUM:
            subprocess.run([GUM, "style", "--foreground", "212", "--bold", "--border", "double", "--padding", "0 2", password])
        else:
            print(f"  {password}")
    elif not has_container:
        gum_section("Cloud-init password (save this!)")
        if GUM:
            subprocess.run([GUM, "style", "--foreground", "212", "--bold", "--border", "double", "--padding", "0 2", password])
        else:
            print(f"  {password}")
    print_info("Start it:  tailvm start " + name)


