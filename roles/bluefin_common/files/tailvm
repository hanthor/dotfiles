def _load_registry() -> dict:
    if not REGISTRY_FILE.exists():
        return {}
    try:
        return json.loads(REGISTRY_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return {}


def _save_registry(reg: dict) -> None:
    REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
    tmp = REGISTRY_FILE.with_suffix(".tmp")
    tmp.write_text(json.dumps(reg, indent=2))
    tmp.rename(REGISTRY_FILE)


def registry_set(name: str, backend: str, extra: dict | None = None) -> None:
    reg = _load_registry()
    reg[name] = {"backend": backend, **(extra or {})}
    _save_registry(reg)


def registry_get(name: str) -> dict | None:
    return _load_registry().get(name)


def registry_remove(name: str) -> None:
    reg = _load_registry()
    reg.pop(name, None)
    _save_registry(reg)


def registry_list() -> dict:
    return _load_registry()


def registry_all_names() -> list[str]:
    """Return sorted list of all registered VM names (both backends)."""
    names = list(_load_registry().keys())
    # Also discover local VMs not in registry (backward compat)
    if BASE_DIR.exists():
        for d in BASE_DIR.iterdir():
            if d.is_dir() and d.name != "cache" and (d / "metadata.json").exists():
                if d.name not in names:
                    names.append(d.name)
    # Also discover KubeVirt VMs not in registry
    try:
        res = subprocess.run(
            ["kubectl", "get", "vms", "-A", "-o",
             "jsonpath={range .items[*]}{.metadata.name}{\"\\n\"}{end}"],
            capture_output=True, text=True,
        )
        for name in res.stdout.strip().split("\n"):
            if name and name not in names:
                names.append(name)
    except Exception:
        pass
    return sorted(names)


