#  Dispatcher
# ═══════════════════════════════════════════════════════════════════

_QEMU_CMDS = {
    "create": cmd_qemu_create, "start": cmd_qemu_start,
    "stop": cmd_qemu_stop, "list": cmd_qemu_list,
    "info": cmd_qemu_info, "delete": cmd_qemu_delete,
    "viewer": cmd_qemu_viewer, "eject": cmd_qemu_eject,
    "logs": cmd_qemu_logs,
}
_KUBEVIRT_CMDS = {
    "create": cmd_kubevirt_create, "start": cmd_kubevirt_start,
    "stop": cmd_kubevirt_stop, "list": cmd_kubevirt_list,
    "info": cmd_kubevirt_info, "delete": cmd_kubevirt_delete,
    "viewer": cmd_kubevirt_viewer, "logs": cmd_kubevirt_logs,
}


def _dispatch(command: str, args: argparse.Namespace) -> None:
    if command == "completion":
        _CMD_COMPLETIONS[command](args)
        return
    if command == "create":
        backend = "kubevirt" if args.kubevirt else "qemu"
        handler = (_KUBEVIRT_CMDS if backend == "kubevirt" else _QEMU_CMDS)[command]
    elif command == "list":
        cmd_qemu_list()
        cmd_kubevirt_list()
        return
    else:
        name = getattr(args, "name", None)
        if not name:
            # Interactive mode — ask user which VM
            name = _interactive_name(command)
            args.name = name
        backend = require_backend(name)
        cmds = _KUBEVIRT_CMDS if backend == "kubevirt" else _QEMU_CMDS
        if command not in cmds:
            print_error(f"'{command}' not supported for backend '{backend}'.")
            sys.exit(1)
        handler = cmds[command]

    handler(args)


