        if res.returncode == 0:
            vm = json.loads(res.stdout)
            spec = vm.get("spec", {})
            tmpl = spec.get("template", {}).get("spec", {})
            dom = tmpl.get("domain", {})
            running = spec.get("running", False)
            ready = vm.get("status", {}).get("ready", False)

            status = ("● Running" if ready else "◐ Pending" if running else "○ Stopped")
            status_color = "212" if ready else "255"
            gum_kv("Status", status, status_color)
            gum_kv("CPU Cores", str(dom.get("cpu", {}).get("cores", "?")), "255")
            gum_kv("Memory", str(dom.get("memory", {}).get("guest", "?")), "255")

            for vol in tmpl.get("volumes", []):
                vname = vol.get("name", "?")
                if "containerDisk" in vol:
                    gum_kv("ContainerDisk", vol["containerDisk"].get("image", "?"), "212")
                elif "persistentVolumeClaim" in vol:
                    gum_kv(f"PVC ({vname})", vol["persistentVolumeClaim"].get("claimName", "?"), "255")
                elif "cloudInitNoCloud" in vol:
                    gum_kv("Cloud-init", "attached", "255")
    except Exception:
        pass

    try:
        res = _kubectl(["get", "vmi", name, "-n", ns, "-o", "json"])
        if res.returncode == 0:
            vmi = json.loads(res.stdout)
            gum_kv("VMI Phase", vmi.get("status", {}).get("phase", "?"), "255")
            gum_kv("Node", vmi.get("status", {}).get("nodeName", "?"), "255")
    except Exception:
        pass

    if entry and "cloud_init_password" in entry:
        gum_kv("Cloud-init pwd", entry["cloud_init_password"], "212")

    # Show ISO DataVolume status if present
    iso_status = _get_datavolume_status(name, ns)
    if iso_status:
        gum_kv("ISO import", iso_status, "212" if "ready" in iso_status else "255")

    gum_section("VNC")
    print_info(f"  virtctl vnc {name} -n {ns}")


def cmd_kubevirt_delete(args: argparse.Namespace) -> None:
    name = args.name or _interactive_name("delete")
    ns = _kubevirt_namespace(name)

    if not args.force and not gum_confirm(f"Delete KubeVirt VM '{name}' and its PVCs?"):
        print_info("Cancelled.")
        return

    try:
        virtctl = _ensure_virtctl()
        subprocess.run([virtctl, "stop", name, "-n", ns], capture_output=True)
    except Exception:
        pass

    gum_spin(
        f"Deleting VM '{name}'",
        ["kubectl", "delete", "vm", name, "-n", ns, "--ignore-not-found"],
        capture_output=True, check=True,
    )

    for suffix in ["disk", "data", "iso"]:
        pvc_name = f"{name}-{suffix}"
        try:
            res = _kubectl([
                "delete", "pvc", pvc_name, "-n", ns, "--ignore-not-found",
            ])
            if "deleted" in (res.stdout + res.stderr):
                print_info(f"Deleted PVC: {pvc_name}")
        except Exception:
            pass
        # Also clean up any DataVolume with the same name
        try:
            res = _kubectl([
                "delete", "datavolume", pvc_name, "-n", ns, "--ignore-not-found",
            ])
            if "deleted" in (res.stdout + res.stderr):
                print_info(f"Deleted DataVolume: {pvc_name}")
        except Exception:
            pass

    registry_remove(name)
    print_success(f"VM '{name}' deleted.")


def cmd_kubevirt_viewer(args: argparse.Namespace) -> None:
    name = args.name or _interactive_name("view")
    ns = _kubevirt_namespace(name)
    virtctl = _ensure_virtctl()

    # Try xdg-open with virtctl proxy, fall back to virtctl vnc directly
    xdg_open = shutil.which("xdg-open")
    if xdg_open:
        import tempfile, threading, time
        port = 5901
        # Find a free port
        import socket
        for p in range(5901, 5910):
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                if s.connect_ex(("127.0.0.1", p)) != 0:
                    port = p
                    break

        print_info(f"Starting VNC proxy on localhost:{port} …")
        # Start virtctl proxy in background
        proxy = subprocess.Popen(
            [virtctl, "vnc", name, "-n", ns, "--proxy-only", f"--port={port}"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        # Give it a moment to start
        time.sleep(1)
        print_info(f"Opening vnc://localhost:{port} …")
        subprocess.Popen([xdg_open, f"vnc://localhost:{port}"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print_success(f"VNC viewer launched! Proxy PID: {proxy.pid}")
        print_info("Close the viewer or press Ctrl+C to stop the proxy.")
        try:
            proxy.wait()
        except KeyboardInterrupt:
            proxy.terminate()
            print()
    else:
        print_info(f"Launching VNC for '{name}' …")
        os.execvp(virtctl, [virtctl, "vnc", name, "-n", ns])


