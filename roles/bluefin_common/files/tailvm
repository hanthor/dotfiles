def cmd_qemu_create(args: argparse.Namespace) -> None:
    qemu_path, qemu_img_path = find_qemu_binaries()
    if not qemu_path or not qemu_img_path:
        print_error("QEMU binaries not found. Install: brew install qemu")
        sys.exit(1)

    vm_dir = BASE_DIR / args.name
    if vm_dir.exists() and not args.force:
        print_error(f"VM '{args.name}' already exists. Use --force to overwrite.")
        sys.exit(1)

    ip = get_tailscale_ip()
    if not ip:
        print_warning("Tailscale offline — VNC will use localhost.")
        ip = "127.0.0.1"
    else:
        print_info(f"Tailscale IP: {ip}")

    resolved_iso = resolve_source(args.iso) if args.iso else None
    resolved_qcow = resolve_source(args.qcow) if args.qcow else None

    display = find_free_vnc_display(ip)
    port = 5900 + display
    print_info(f"VNC display :{display} (port {port})")

    vm_dir.mkdir(parents=True, exist_ok=True)
    SYSTEMD_USER_DIR.mkdir(parents=True, exist_ok=True)

    disk_path = vm_dir / "disk.qcow2"

    if resolved_qcow:
        print_info("Copying QCOW2 template …")
        shutil.copy2(resolved_qcow, disk_path)
        os.chmod(disk_path, 0o644)
        if args.disk:
            print_info(f"Resizing to {args.disk} …")
            gum_spin(
                f"Resizing disk to {args.disk}",
                [qemu_img_path, "resize", str(disk_path), args.disk],
                capture_output=True, check=True,
            )
    else:
        disk_size = args.disk or "20G"
        print_info(f"Creating {disk_size} QCOW2 disk …")
        gum_spin(
            f"Creating {disk_size} virtual disk",
            [qemu_img_path, "create", "-f", "qcow2",
             str(disk_path), disk_size],
            capture_output=True, check=True,
        )

    service_content = generate_systemd_unit(
        name=args.name, qemu_path=qemu_path, mem=args.mem,
        cpu=args.cpu, disk_path=str(disk_path),
        iso_path=resolved_iso, tailscale_ip=ip,
        vnc_display=display, has_iso=bool(resolved_iso),
    )
    (SYSTEMD_USER_DIR / f"tailvm-{args.name}.service").write_text(service_content)

    metadata = {
        "name": args.name,
        "iso": resolved_iso,
        "has_iso": bool(resolved_iso),
        "qcow_template": resolved_qcow,
        "disk_size": args.disk or ("Template Default" if resolved_qcow else "20G"),
        "memory": args.mem,
        "cpu": args.cpu,
        "vnc_display": display,
        "vnc_port": port,
        "tailscale_ip": ip,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
    }
    (vm_dir / "metadata.json").write_text(json.dumps(metadata, indent=2))
    registry_set(args.name, "qemu", {"namespace": "default"})
    daemon_reload()

    gum_print_header(f"VM '{args.name}' created!")
    print_info(f"Start it:  tailvm start {args.name}")
    print_info(f"VNC URL:    vnc://{ip}:{port}")


