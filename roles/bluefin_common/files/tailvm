def main() -> None:
    # Internal completion mode: tailvm _complete <shell> "<words>" <cword>
    if len(sys.argv) >= 4 and sys.argv[1] == "_complete":
        _handle_complete(sys.argv[3], int(sys.argv[4]))
        return

    parser = argparse.ArgumentParser(
        description="TailVM — QEMU/KubeVirt VMs with Tailscale VNC",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # create
    pc = sub.add_parser("create", help="Create a VM")
    pc.add_argument("name", help="VM name")
    pc.add_argument("--kubevirt", "-k", action="store_true",
                    help="Use KubeVirt backend")
    pc.add_argument("--mem", default="4G", help="Memory (default: 4G)")
    pc.add_argument("--cpu", type=int, default=2, help="CPU cores (default: 2)")
    pc.add_argument("--disk", default=None, help="Disk size (default: 20G)")
    # QEMU / KubeVirt
    pc.add_argument("--iso", default=None,
                    help="ISO path/URL (QEMU: local ISO, KubeVirt: CDI imports from URL into PVC)")
    pc.add_argument("--qcow", default=None, help="[qemu] QCOW2 template")
    pc.add_argument("--force", action="store_true", help="Overwrite existing VM")
    # KubeVirt
    pc.add_argument("--container-disk", default=None,
                    help="[kubevirt] Container disk image")
    pc.add_argument("--pvc", default=None, help="[kubevirt] Existing PVC")
    pc.add_argument("--namespace", "-n", default="default", help="[kubevirt] Namespace")
    pc.add_argument("--node", default=None, help="[kubevirt] Schedule on node")
    pc.add_argument("--cloud-init-password", default=None,
                    help="[kubevirt] Cloud-init password")
    pc.add_argument("--cloud-init", default=None,
                    help="[kubevirt] Extra cloud-init user-data YAML (e.g. Tailscale/SSH keys)")

    # start / stop / info / delete / viewer / eject / logs
    for cmd, help_text in [
        ("start", "Start a VM"), ("stop", "Stop a VM"),
        ("info", "Show VM details"), ("delete", "Delete a VM"),
        ("viewer", "Launch VNC viewer"), ("eject", "Eject ISO (QEMU)"),
        ("logs", "Tail VM logs"),
    ]:
        sp = sub.add_parser(cmd, help=help_text)
        sp.add_argument("name", nargs="?", default=None, help="VM name (omit to pick interactively)")
        if cmd == "start":
            sp.add_argument("--no-viewer", action="store_true")
        if cmd == "delete":
            sp.add_argument("--force", "-f", action="store_true",
                            help="Skip confirmation")

    # list
    sub.add_parser("list", help="List all VMs (both backends)")

    # completion
    comp = sub.add_parser("completion", help="Generate shell completions")
    comp.add_argument("shell", choices=["bash", "zsh", "fish"],
                       help="Shell to generate completions for")

    args = parser.parse_args()
    if not args.command:
        cmd_menu()
        return

    try:
        _dispatch(args.command, args)
    except KeyboardInterrupt:
        print()
        sys.exit(130)
    except subprocess.CalledProcessError as e:
        print_error(f"Command failed: {e}")
        sys.exit(e.returncode)


if __name__ == "__main__":
    main()
