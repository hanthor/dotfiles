def _vnc_proxy_svc(name: str, ns: str, node_port: int) -> str:
    """Service exposed via Tailscale operator (tailscale.com/expose)."""
    return f'''apiVersion: v1
kind: Service
metadata:
  name: {name}-vnc
  namespace: {ns}
  annotations:
    tailscale.com/expose: "true"
    tailscale.com/hostname: "{name}-vm"
spec:
  type: ClusterIP
  selector:
    app: tailvm-vnc-proxy
    vm: "{name}"
  ports:
    - port: 5900
      targetPort: 5900
      name: vnc
      protocol: TCP
'''


def _vnc_proxy_tailnet_host(name: str) -> str:
    """Return the Tailscale DNS name for a VNC proxy."""
    return f"{name}-vm.manatee-basking.ts.net"


def _vnc_proxy_get_nodeport(name: str, ns: str) -> int | None:
    """Get the Tailscale hostname for the VNC proxy, or None."""
    try:
        res = _kubectl(["get", "svc", f"{name}-vnc", "-n", ns, "-o", "json"])
        if res.returncode != 0:
            return None
        svc = json.loads(res.stdout)
        ann = svc.get("metadata", {}).get("annotations", {})
        if ann.get("tailscale.com/expose") == "true":
            return 5900  # Tailscale-exposed, return standard port
    except Exception:
        pass
    return None


def _vnc_proxy_status(name: str, ns: str) -> str:
    """Return 'on', 'pending', or 'off' for VNC proxy status."""
    try:
        res = _kubectl(["get", "deploy", f"{name}-vnc-proxy", "-n", ns, "-o", "json"])
        if res.returncode != 0:
            return "off"
        deploy = json.loads(res.stdout)
        ready = deploy.get("status", {}).get("readyReplicas", 0)
        if ready > 0:
            return "on"
        return "pending"
    except Exception:
        return "off"


def _vnc_proxy_enable(name: str, ns: str) -> None:
    """Enable VNC proxy for a KubeVirt VM. Exposes via Tailscale operator."""
    gum_spin("Creating VNC RBAC", ["kubectl", "apply", "-f", "-"],
             input=_vnc_proxy_rbac(name, ns), text=True, capture_output=True, check=True)
    gum_spin("Creating VNC Service", ["kubectl", "apply", "-f", "-"],
             input=_vnc_proxy_svc(name, ns, 0), text=True, capture_output=True, check=True)
    gum_spin("Creating VNC proxy", ["kubectl", "apply", "-f", "-"],
             input=_VNC_PROXY_MANIFEST.format(name=name, ns=ns, image=_VNC_PROXY_IMAGE),
             text=True, capture_output=True, check=True)
    host = _vnc_proxy_tailnet_host(name)
    print_success(f"VNC enabled: vnc://{host}")


def _vnc_proxy_disable(name: str, ns: str) -> None:
    """Disable VNC proxy for a KubeVirt VM."""
    for resource in ["deploy", "svc", "sa", "role", "rolebinding"]:
        rname = f"{name}-vnc-proxy" if resource == "deploy" else (
            f"{name}-vnc" if resource == "svc" else f"tailvm-{name}-vnc")
        subprocess.run(["kubectl", "delete", resource, rname, "-n", ns, "--ignore-not-found"],
                       capture_output=True)
    print_success(f"VNC proxy disabled for {name}")


