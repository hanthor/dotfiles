def _gum_choose(options: list[str], prompt: str = "Choose:", height: int = 0) -> str | None:
    """Present a gum choose list, return selected item or None."""
    if not GUM:
        print(prompt)
        for i, o in enumerate(options):
            print(f"  {i+1}. {o}")
        try:
            idx = int(input("> ")) - 1
            return options[idx] if 0 <= idx < len(options) else None
        except (ValueError, EOFError):
            return None
    args = [GUM, "choose", "--cursor.foreground", "212"]
    if height:
        args.extend(["--height", str(height)])
    res = subprocess.run(args, input="\n".join(options),
                         capture_output=True, text=True)
    return res.stdout.strip() if res.returncode == 0 else None


def _gum_confirm(prompt: str) -> bool:
    """Ask y/n confirmation."""
    if not GUM:
        return input(f"{prompt} [y/N] ").lower().startswith("y")
    return subprocess.run([GUM, "confirm", prompt], capture_output=True).returncode == 0


def _kubevirt_vm_list_items() -> list[dict]:
    """Return list of KubeVirt VMs with metadata for the TUI."""
    items = []
    try:
        res = _kubectl(["get", "vms", "-A", "-o", "json"])
        if res.returncode != 0:
            return items
        vms = json.loads(res.stdout).get("items", [])
        for vm in vms:
            md = vm.get("metadata", {})
            name = md.get("name", "?")
            ns = md.get("namespace", "?")
            spec = vm.get("spec", {})
            tmpl = spec.get("template", {}).get("spec", {})
            dom = tmpl.get("domain", {})
            cpu = dom.get("cpu", {}).get("cores", "?")
            mem = dom.get("memory", {}).get("guest", "?")
            ready = vm.get("status", {}).get("ready", False)
            running = spec.get("running", False)
            iso_status = _get_datavolume_status(name, ns)
            if ready:
                status = "● Running"
            elif iso_status:
                status = iso_status
            elif running:
                status = "◐ Starting"
            else:
                status = "○ Stopped"
            vnc = _vnc_proxy_status(name, ns)
            items.append({
                "name": name, "ns": ns, "cpu": cpu, "mem": mem,
                "status": status, "ready": ready, "running": running,
                "vnc": vnc,
            })
    except Exception:
        pass
    return items


def _qemu_vm_list_items() -> list[dict]:
    """Return list of QEMU VMs with metadata."""
    items = []
    if not BASE_DIR.exists():
        return items
    for d in sorted(BASE_DIR.iterdir()):
        if not d.is_dir() or d.name == "cache":
            continue
        meta_file = d / "metadata.json"
        if not meta_file.exists():
            continue
        try:
            meta = json.loads(meta_file.read_text())
            svc = f"tailvm-{meta['name']}"
            res = subprocess.run(["systemctl", "--user", "is-active", svc],
                                 capture_output=True, text=True)
            is_active = res.stdout.strip() == "active"
            items.append({
                "name": meta["name"], "ns": "—", "cpu": meta.get("cpu", "?"),
                "mem": meta.get("memory", "?"),
                "status": "● Running" if is_active else "○ Stopped",
                "ready": is_active, "running": is_active,
                "vnc": "—",
            })
        except Exception:
            pass
    return items


def _edit_menu(vm: dict) -> None:
    """Edit toggles for a VM: VNC, SSH, RDP."""
    name = vm["name"]
    ns = vm.get("ns", "default")
    backend = require_backend(name)

    if backend != "kubevirt":
        print_info("Edit menu is for KubeVirt VMs only.")
        return

    while True:
        vnc_status = _vnc_proxy_status(name, ns)
        vnc_label = f"VNC  [{vnc_status.upper()}]"
        if vnc_status == "on":
            host = _vnc_proxy_tailnet_host(name)
            vnc_label += f"  — vnc://{host}"
        ssh_label = f"SSH  [OFF]"
        rdp_label = f"RDP  [OFF]"

        choice = _gum_choose(
            [vnc_label, ssh_label, rdp_label, "← Back"],
            prompt=f"Edit {name} — toggle services:",
            height=6,
        )
        if not choice or "Back" in choice:
            return
        if "VNC" in choice:
            if vnc_status == "on":
                _vnc_proxy_disable(name, ns)
            else:
                _vnc_proxy_enable(name, ns)
            time.sleep(0.5)
        if "SSH" in choice:
            print_info("SSH toggle coming soon.")
        if "RDP" in choice:
            print_info("RDP toggle coming soon.")


def _action_menu(vm: dict) -> None:
    """Action menu for a selected VM."""
    name = vm["name"]
    ns = vm.get("ns", "default")
    backend = require_backend(name)
    ready = vm.get("ready", False)
    running = vm.get("running", False)

    actions = []
    if not ready:
        actions.append("▶  Start")
    if ready or running:
        actions.append("■  Stop")
    actions.append("ℹ  Info")
    if backend == "kubevirt":
        actions.append("🖵  Viewer (VNC)")
    actions.append("✎  Edit (VNC/SSH/RDP)")
    actions.append("✕  Delete")
    actions.append("← Back")

    choice = _gum_choose(actions, prompt=f"{name} ({backend}):", height=10)
    if not choice or "Back" in choice:
        return

    if "Start" in choice:
        if backend == "kubevirt":
            cmd_kubevirt_start(argparse.Namespace(name=name, no_viewer=False))
        else:
            cmd_qemu_start(argparse.Namespace(name=name, no_viewer=True))
    elif "Stop" in choice:
        if backend == "kubevirt":
            cmd_kubevirt_stop(argparse.Namespace(name=name))
        else:
            cmd_qemu_stop(argparse.Namespace(name=name))
    elif "Info" in choice:
        if backend == "kubevirt":
            cmd_kubevirt_info(argparse.Namespace(name=name))
        else:
            cmd_qemu_info(argparse.Namespace(name=name))
    elif "Viewer" in choice:
        if backend == "kubevirt":
            cmd_kubevirt_viewer(argparse.Namespace(name=name))
    elif "Edit" in choice:
        _edit_menu(vm)
    elif "Delete" in choice:
        if backend == "kubevirt":
            cmd_kubevirt_delete(argparse.Namespace(name=name, force=False))
        else:
            cmd_qemu_delete(argparse.Namespace(name=name, force=False))


def cmd_menu() -> None:
    """Interactive TUI: list VMs → select → action/edit."""
    # Fall back to plain list if not in a terminal
    if not sys.stdin.isatty():
        cmd_qemu_list()
        cmd_kubevirt_list()
        return

    while True:
        # Refresh VM lists
        qemu_vms = _qemu_vm_list_items()
        kubevirt_vms = _kubevirt_vm_list_items()
        all_vms = qemu_vms + kubevirt_vms

        if not all_vms:
            gum_print_header("TailVM — No VMs found")
            print_info("Create one:  tailvm create <name>")
            print_info("  tailvm create <name> --kubevirt  (for KubeVirt)")
            return

        # Build display list: "NAME  STATUS  VNC  CPU/MEM"
        lines = []
        for vm in all_vms:
            vnc_icon = "🔵" if vm.get("vnc") == "on" else ("⏳" if vm.get("vnc") == "pending" else "○")
            lines.append(f"{vm['name']:20s}  {vm['status']:16s}  VNC:{vnc_icon}  CPU:{vm['cpu']}  MEM:{vm['mem']}")

        choice = _gum_choose(lines + ["← Quit"], prompt="TailVM — select a VM:", height=min(len(lines) + 2, 15))
        if not choice or "Quit" in choice:
            return

        # Extract VM name from display line
        vm_name = choice.split()[0]
        vm = next((v for v in all_vms if v["name"] == vm_name), None)
        if vm:
            _action_menu(vm)

_COMMANDS = ["create", "start", "stop", "list", "info", "delete",
             "viewer", "eject", "logs", "completion"]
_CREATE_FLAGS = ["--kubevirt", "-k", "--mem", "--cpu", "--disk", "--iso",
                 "--qcow", "--force", "--container-disk", "--pvc",
                 "--namespace", "-n", "--node", "--cloud-init-password",
                 "--cloud-init"]


def _all_vm_names() -> list[str]:
    """Collect VM names from both backends."""
    names: list[str] = []
    # QEMU VMs from local dir
    if BASE_DIR.exists():
        for item in BASE_DIR.iterdir():
            if item.is_dir() and item.name != "cache" and (item / "metadata.json").exists():
                names.append(item.name)
    # KubeVirt VMs from cluster
    try:
        res = _kubectl(["get", "vms", "-A", "-o", "jsonpath={.items[*].metadata.name}"])
        if res.returncode == 0:
            names.extend(res.stdout.strip().split())
    except Exception:
        pass
    return sorted(set(names))


def _generate_completion_bash() -> str:
    return '''# tailvm bash completion
_tailvm_completion() {
    local cur prev words cword
    _init_completion || return
    COMPREPLY=($(tailvm _complete bash "${COMP_WORDS[*]}" "$COMP_CWORD"))
}
complete -F _tailvm_completion tailvm
'''


def _generate_completion_zsh() -> str:
    return '''#compdef tailvm
# tailvm zsh completion
_tailvm() {
    local -a completions
    completions=(${(f)"$(tailvm _complete zsh "${words[*]}" "$CURRENT")"})
    compadd -a completions
}
_tailvm
'''


def _generate_completion_fish() -> str:
    return '''# tailvm fish completion
function __tailvm_complete
    tailvm _complete fish "$argv" (math (count (commandline -opc)) + 1)
end
complete -c tailvm -f -a '(__tailvm_complete (commandline -opc))'
'''


def _handle_complete(args_str: str, cword: int) -> None:
    """Internal completer: prints matching completions, one per line."""
    words = args_str.split()
    # Remove the program name (tailvm)
    if words and words[0] in ("tailvm", os.path.basename(sys.argv[0])):
        words = words[1:]
        cword -= 1

    # cword beyond len(words) means completing at the end (trailing space)
    cur = words[cword] if cword < len(words) else ""

    # Completing the command name (first word, or no words yet)
    if cword <= 0:
        for cmd in _COMMANDS:
            if cur == "" or cmd.startswith(cur):
                print(cmd)
        return

    command = words[0]

    # create: complete flags (cword 2+)
    if command == "create":
        if cur.startswith("-"):
            for flag in _CREATE_FLAGS:
                if cur == "" or flag.startswith(cur):
                    print(flag)
        return

    # completion: complete shell names
    if command == "completion":
        for shell in ["bash", "zsh", "fish"]:
            if cur == "" or shell.startswith(cur):
                print(shell)
        return

    # Commands that take a VM name (second argument)
    if command in ("start", "stop", "info", "delete", "viewer", "eject", "logs"):
        for name in _all_vm_names():
            if cur == "" or name.startswith(cur):
                print(name)
        return


_CMD_COMPLETIONS = {
    "completion": lambda args: (
        print(f"# tailvm {args.shell} completion — source this file or add to your shell rc:"),
        print(f"#   tailvm completion {args.shell} > ~/.tailvm-completion.{args.shell}"),
        print(f"#   echo 'source ~/.tailvm-completion.{args.shell}' >> ~/.{args.shell}rc"),
        print(),
        print({ "bash": _generate_completion_bash(),
                "zsh": _generate_completion_zsh(),
                "fish": _generate_completion_fish(),
              }.get(args.shell, ""))),
}


