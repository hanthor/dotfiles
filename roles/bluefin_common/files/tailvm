def _get_datavolume_status(name: str, ns: str) -> str | None:
    """Return a status string for a VM's ISO DataVolume, or None if no DV."""
    try:
        res = _kubectl(["get", "datavolume", f"{name}-iso", "-n", ns, "-o", "json"])
        if res.returncode != 0:
            return None
        dv = json.loads(res.stdout)
        phase = dv.get("status", {}).get("phase", "?")
        progress = dv.get("status", {}).get("progress", "")
        if phase in ("Succeeded",):
            return "✓ ready"
        if phase in ("ImportInProgress", "ImportScheduled"):
            pct = f" {progress}" if progress else ""
            return f"↓{pct}"
        if phase in ("Pending", "PVCBound", "WaitForFirstConsumer"):
            return "↓ queued"
        return f"↓ {phase}"
    except Exception:
        return None


def cmd_kubevirt_list() -> None:
    try:
        res = _kubectl(["get", "vms", "-A", "-o", "json"])
        if res.returncode != 0:
            return
        vms = json.loads(res.stdout).get("items", [])
    except Exception:
        return

    rows: list[list[str]] = []
    for vm in vms:
        md = vm.get("metadata", {})
        name = md.get("name", "?")
        ns = md.get("namespace", "?")
        spec = vm.get("spec", {})
        tmpl = spec.get("template", {}).get("spec", {})
        dom = tmpl.get("domain", {})
        cpu = dom.get("cpu", {}).get("cores", "?")
        mem = dom.get("memory", {}).get("guest", "?")
        node = tmpl.get("nodeSelector", {}).get("kubernetes.io/hostname", "—")
        ready = vm.get("status", {}).get("ready", False)
        iso_status = _get_datavolume_status(name, ns)
        if ready:
            status = "● Running"
        elif iso_status:
            status = iso_status
        else:
            status = "○ Stopped"
        rows.append([name, "kubevirt", status, ns, str(cpu), str(mem), str(node)])

    if rows:
        gum_table(
            ["NAME", "BACKEND", "STATUS", "NAMESPACE", "CPU", "MEM", "NODE"],
            rows,
        )


