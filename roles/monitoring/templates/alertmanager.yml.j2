global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'machine']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: matrix

receivers:
  - name: matrix
    webhook_configs:
      - url: 'http://matrix-notifier:8080/alert'
        send_resolved: true

inhibit_rules:
  - source_matchers:
      - severity="critical"
    target_matchers:
      - severity="warning"
    equal: ['alertname', 'machine', 'device']
