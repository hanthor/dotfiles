global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    machine: {{ inventory_hostname }}

{% if monitoring_hub | default(false) | bool %}
alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:9093']

rule_files:
  - /etc/prometheus/alerts/*.yml

scrape_configs:
  - job_name: 'node'
    static_configs:
      - targets: ['node_exporter:9100']
    relabel_configs:
      - target_label: machine
        replacement: {{ inventory_hostname }}

  - job_name: 'podman'
    static_configs:
      - targets: ['podman_exporter:9882']
    relabel_configs:
      - target_label: machine
        replacement: {{ inventory_hostname }}

  - job_name: 'proxmox'
    metrics_path: /pve
    params:
      module: [default]
    static_configs:
      - targets: ['100.85.9.86']
        labels:
          machine: bihar
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: pve_exporter:9221
{% else %}
scrape_configs:
  - job_name: 'node'
    static_configs:
      - targets: ['node_exporter:9100']

  - job_name: 'podman'
    static_configs:
      - targets: ['podman_exporter:9882']

remote_write:
  - url: 'http://100.104.213.39:9091/api/v1/write'
    queue_config:
      max_samples_per_send: 1000
      max_shards: 5
{% endif %}
