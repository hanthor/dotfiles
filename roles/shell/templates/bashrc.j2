# Homebrew
if [ -d /home/linuxbrew/.linuxbrew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Bluefin CLI shell integration (handles eza, bat, zoxide, starship, atuin, etc.)
# Guard with interactive check: atuin's AI keybinding calls `bind` outside its
# interactive guard, causing "bind: warning: line editing not enabled" in
# non-interactive shells (e.g. SSH remote commands).
[[ $- == *i* ]] && command -v bluefin-cli &>/dev/null && eval "$(bluefin-cli init bash)"

# Custom aliases (git, k8s, vim, etc.)
[ -f ~/.config/shell/aliases.sh ] && source ~/.config/shell/aliases.sh
