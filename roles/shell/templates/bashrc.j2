{% if inventory_hostname in tmux_ssh_machines %}
# Start tmux with fish for SSH sessions
if [ -z "$TMUX" ] && [ -n "$SSH_CONNECTION" ]; then
  if command -v tmux &>/dev/null && [ -x /home/linuxbrew/.linuxbrew/bin/fish ]; then
    exec tmux new-session /home/linuxbrew/.linuxbrew/bin/fish
  fi
fi
{% endif %}

# Homebrew
if [ -d /home/linuxbrew/.linuxbrew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Bluefin CLI shell integration (handles eza, bat, zoxide, starship, atuin, etc.)
command -v bluefin-cli &>/dev/null && eval "$(bluefin-cli init bash)"

# Custom aliases (git, k8s, vim, etc.)
[ -f ~/.config/shell/aliases.sh ] && source ~/.config/shell/aliases.sh
