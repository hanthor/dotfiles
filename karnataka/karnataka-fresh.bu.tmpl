storage:
  filesystems:
    - device: /dev/disk/by-uuid/efcecc3a-1350-4ea0-9668-04fd71590ccf
      format: ext4
      path: /var/lib/state
      wipe_filesystem: false

  files:
    - path: /opt/extensions/kubernetes/kubernetes-v1.33.2-x86-64.raw
      contents:
        source: https://extensions.flatcar.org/extensions/kubernetes-v1.33.2-x86-64.raw
    - path: /opt/extensions/tailscale/tailscale-v1.98.3-x86-64.raw
      contents:
        source: https://github.com/flatcar/sysext-bakery/releases/download/tailscale-v1.98.3/tailscale-v1.98.3-x86-64.raw
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: karnataka
    - path: /etc/systemd/network/20-dhcp.network
      mode: 0644
      contents:
        inline: |
          [Match]
          Name=enp191s0

          [Network]
          DHCP=yes
    - path: /etc/sudoers.d/99-core-james
      mode: 0440
      contents:
        inline: |
          core ALL=(ALL) NOPASSWD: ALL
          james ALL=(ALL) NOPASSWD: ALL
    - path: /etc/tailscale/tailscale.env
      mode: 0600
      user:
        name: root
      group:
        name: root
      contents:
        inline: |
          TS_AUTHKEY={{TS_AUTHKEY}}
          TS_STATE_DIR=/var/lib/tailscale

  links:
    - path: /etc/extensions/kubernetes.raw
      target: /opt/extensions/kubernetes/kubernetes-v1.33.2-x86-64.raw
    - path: /etc/extensions/tailscale.raw
      target: /opt/extensions/tailscale/tailscale-v1.98.3-x86-64.raw

systemd:
  units:
    - name: prepare-overlay-dirs.service
      enabled: true
      contents: |
        [Unit]
        Description=Prepare Writable Overlay and Bind-mount Directories
        Requires=var-lib-state.mount
        After=var-lib-state.mount
        Before=usr-lib-modules.mount usr-lib-firmware.mount var-lib-etcd.mount var-lib-kubelet.mount etc-kubernetes.mount var-lib-tailscale.mount
        [Service]
        Type=oneshot
        ExecStart=/usr/bin/mkdir -p /var/lib/state/modules /var/lib/state/modules_work /var/lib/state/firmware /var/lib/state/firmware_work /var/lib/state/etcd /var/lib/state/kubelet /var/lib/state/etc-kubernetes /var/lib/state/tailscale
        RemainAfterExit=yes
        [Install]
        WantedBy=multi-user.target

    - name: usr-lib-modules.mount
      enabled: true
      contents: |
        [Unit]
        Description=Overlay for Writable Kernel Modules
        Requires=var-lib-state.mount prepare-overlay-dirs.service
        After=prepare-overlay-dirs.service
        [Mount]
        What=overlay
        Where=/usr/lib/modules
        Type=overlay
        Options=lowerdir=/usr/lib/modules,upperdir=/var/lib/state/modules,workdir=/var/lib/state/modules_work
        [Install]
        WantedBy=multi-user.target

    - name: run-depmod.service
      enabled: true
      contents: |
        [Unit]
        Description=Regenerate Kernel Module Dependencies and Load AMDGPU
        Requires=usr-lib-modules.mount
        After=usr-lib-modules.mount
        Before=kubelet.service
        [Service]
        Type=oneshot
        ExecStart=/usr/sbin/depmod -a
        ExecStartPost=/usr/sbin/modprobe amdgpu
        RemainAfterExit=yes
        [Install]
        WantedBy=multi-user.target

    - name: usr-lib-firmware.mount
      enabled: true
      contents: | |
        [Unit]
        Description=Overlay for Writable Firmware
        Requires=var-lib-state.mount prepare-overlay-dirs.service
        After=prepare-overlay-dirs.service
        [Mount]
        What=overlay
        Where=/usr/lib/firmware
        Type=overlay
        Options=lowerdir=/usr/lib/firmware,upperdir=/var/lib/state/firmware,workdir=/var/lib/state/firmware_work
        [Install]
        WantedBy=multi-user.target

    - name: systemd-sysext.service
      enabled: true
    - name: systemd-sysupdate.timer
      enabled: true
    - name: locksmithd.service
      mask: true
    - name: tailscale-oneshot.service
      enabled: true
      contents: |
        [Unit]
        Description=Tailscale oneshot
        After=network-online.target
        Wants=network-online.target

        [Service]
        Type=oneshot
        ExecStart=/usr/bin/tailscale up
        RemainAfterExit=yes

        [Install]
        WantedBy=multi-user.target

    # Mount the persistent NVMe partition early in the boot sequence
    - name: var-lib-state.mount
      enabled: true
      contents: |
        [Unit]
        Description=Mount Persistent NVMe Partition
        Before=local-fs.target
        [Mount]
        What=/dev/disk/by-uuid/efcecc3a-1350-4ea0-9668-04fd71590ccf
        Where=/var/lib/state
        Type=ext4
        Options=defaults,noatime
        [Install]
        WantedBy=multi-user.target

    # Systemd Bind Mount for ETCD cluster database
    - name: var-lib-etcd.mount
      enabled: true
      contents: |
        [Unit]
        Description=Bind Mount Persistent ETCD Storage
        Requires=var-lib-state.mount
        After=var-lib-state.mount
        Before=kubelet.service
        [Mount]
        What=/var/lib/state/etcd
        Where=/var/lib/etcd
        Type=none
        Options=bind
        [Install]
        WantedBy=multi-user.target

    # Systemd Bind Mount for Kubelet pod configuration
    - name: var-lib-kubelet.mount
      enabled: true
      contents: |
        [Unit]
        Description=Bind Mount Persistent Kubelet Storage
        Requires=var-lib-state.mount
        After=var-lib-state.mount
        Before=kubelet.service
        [Mount]
        What=/var/lib/state/kubelet
        Where=/var/lib/kubelet
        Type=none
        Options=bind
        [Install]
        WantedBy=multi-user.target

    # Systemd Bind Mount for Kubernetes configuration and certs
    - name: etc-kubernetes.mount
      enabled: true
      contents: |
        [Unit]
        Description=Bind Mount Persistent Kubernetes Configuration
        Requires=var-lib-state.mount
        After=var-lib-state.mount
        Before=kubelet.service
        [Mount]
        What=/var/lib/state/etc-kubernetes
        Where=/etc/kubernetes
        Type=none
        Options=bind
        [Install]
        WantedBy=multi-user.target

    # Systemd Bind Mount for Tailscale node credentials
    - name: var-lib-tailscale.mount
      enabled: true
      contents: |
        [Unit]
        Description=Bind Mount Persistent Tailscale Storage
        Requires=var-lib-state.mount
        After=var-lib-state.mount
        Before=tailscaled.service
        [Mount]
        What=/var/lib/state/tailscale
        Where=/var/lib/tailscale
        Type=none
        Options=bind
        [Install]
        WantedBy=multi-user.target
