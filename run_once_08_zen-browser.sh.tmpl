{{ if not .isDesktop }}#!/usr/bin/env bash
echo "Not a desktop machine, skipping Zen Browser setup."
exit 0
{{ else }}#!/usr/bin/env bash
set -euo pipefail

ZEN_BASE="$HOME/.var/app/app.zen_browser.zen/.zen"
PROFILES_INI="$ZEN_BASE/profiles.ini"

# Skip if Zen Browser Flatpak is not installed
if ! flatpak list 2>/dev/null | grep -q "app.zen_browser.zen"; then
  echo "Zen Browser not installed, skipping."
  exit 0
fi

# Find the default profile directory by reading profiles.ini
if [ ! -f "$PROFILES_INI" ]; then
  echo "profiles.ini not found — Zen Browser has never been launched."
  echo "Please launch Zen Browser once, then re-run: chezmoi apply --force"
  exit 0
fi

# Parse the Default=1 profile's Path
PROFILE_REL=$(python3 -c "
import configparser, sys
cfg = configparser.ConfigParser()
cfg.read('$PROFILES_INI')
for s in cfg.sections():
    if cfg.get(s, 'Default', fallback='0') == '1':
        print(cfg.get(s, 'Path'))
        sys.exit(0)
for s in cfg.sections():
    if s.startswith('Install'):
        print(cfg.get(s, 'Default', fallback=''))
        sys.exit(0)
")

PROFILE_DIR="$ZEN_BASE/$PROFILE_REL"

if [ -z "$PROFILE_REL" ] || [ ! -d "$PROFILE_DIR" ]; then
  echo "ERROR: Could not determine Zen profile directory from $PROFILES_INI"
  echo "Profile path resolved to: $PROFILE_DIR"
  exit 1
fi

echo "Zen Browser profile: $PROFILE_DIR"

# Copy user.js
cp "$HOME/.config/zen-browser/user.js" "$PROFILE_DIR/user.js"
echo "user.js copied."

# Write policies.json to the distribution directory
DIST_DIR="$ZEN_BASE/distribution"
mkdir -p "$DIST_DIR"
cp "$HOME/.config/zen-browser/policies.json" "$DIST_DIR/policies.json"
echo "policies.json written to $DIST_DIR"

echo "Zen Browser configured. Launch it to complete Firefox Sync and Bitwarden setup."
echo ""
echo "Post-setup steps:"
echo "  1. Hamburger menu → Sign in to Sync → approve on phone"
echo "  2. Click Bitwarden extension → enter master password"
{{ end }}
