{
  "mcpServers": {
    "netbox-rw": {
      "command": "uv",
      "args": [
        "--directory",
        "tools/netbox-mcp-rw",
        "run",
        "--python",
        "python3.13",
        "server.py"
      ],
      "env": {
        "NETBOX_URL": "https://bihar.manatee-basking.ts.net/netbox",
        "NETBOX_TOKEN": "$NETBOX_API_TOKEN"
      }
    }
  }
}
