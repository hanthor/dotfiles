# Flatpak applications managed by chezmoi
# run_onchange_11_flatpaks.sh.tmpl installs these on desktop machines.
# Local dev remotes (pasar-local, wailbrew-local, etc.) are excluded —
# those are machine-specific and managed manually.

[remotes]
# name=url  (system remotes need sudo; user remotes do not)
flathub=https://dl.flathub.org/repo/

